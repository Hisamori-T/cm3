# ==================================================
# Construction Manager v3 - 本番環境変数
# このファイルをサーバーの /root/cmv3/.env にコピーして値を設定してください
# git には絶対にコミットしないこと
# ==================================================

# --------------------------------------------------
# Database（既存 postgres コンテナを使用）
# --------------------------------------------------
POSTGRES_DB=cmv3
POSTGRES_USER=cmv3user
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
DATABASE_URL=postgresql+asyncpg://cmv3user:CHANGE_THIS_STRONG_PASSWORD@postgres:5432/cmv3

# --------------------------------------------------
# Redis
# --------------------------------------------------
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_THIS_REDIS_PASSWORD@cmv3-redis:6379/0

# --------------------------------------------------
# AI（Google Gemini）
# --------------------------------------------------
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# --------------------------------------------------
# 認証（JWT）
# --------------------------------------------------
# 生成コマンド: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_THIS_TO_RANDOM_64_CHAR_HEX
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --------------------------------------------------
# CORS / フロントエンドURL
# --------------------------------------------------
ALLOWED_ORIGINS=https://cmv3.fact-ally.com
NEXT_PUBLIC_API_URL=https://cmv3.fact-ally.com

# --------------------------------------------------
# アプリケーション
# --------------------------------------------------
APP_ENV=production
LOG_LEVEL=INFO
