# ==================================================
# Construction Manager v3 - 環境変数サンプル
# このファイルをコピーして .env を作成してください
# cp .env.example .env
# ==================================================

# --------------------------------------------------
# Database
# --------------------------------------------------
POSTGRES_DB=cmv3
POSTGRES_USER=cmv3user
POSTGRES_PASSWORD=cmv3pass_change_in_production
DATABASE_URL=postgresql+asyncpg://cmv3user:cmv3pass_change_in_production@cmv3-db:5432/cmv3

# --------------------------------------------------
# Redis
# --------------------------------------------------
REDIS_PASSWORD=cmv3redis_change_in_production
REDIS_URL=redis://:cmv3redis_change_in_production@cmv3-redis:6379/0

# --------------------------------------------------
# AI（Google Gemini）
# --------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# --------------------------------------------------
# 認証（JWT）
# --------------------------------------------------
# 本番では必ず変更すること（最低32文字のランダム文字列）
# 生成例: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_this_to_a_random_secret_key_min_32_chars
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --------------------------------------------------
# CORS
# --------------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000

# --------------------------------------------------
# アプリケーション
# --------------------------------------------------
APP_ENV=development
LOG_LEVEL=INFO

# --------------------------------------------------
# 管理者初期アカウント（シードスクリプト用）
# --------------------------------------------------
ADMIN_EMAIL=admin@clap-corp.example
ADMIN_PASSWORD=change_in_production
